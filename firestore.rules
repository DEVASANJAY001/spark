rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated();
    }

    // Check if user is part of a match
    function isParticipant(matchData) {
      return isAuthenticated() && (request.auth.uid in matchData.users);
    }

    // --- COLLECTIONS ---

    // USERS: Everyone can read basic profiles, but only owners can update.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update, delete: if isAdmin() || isOwner(userId);
      
      match /swipes/{targetId} {
        allow read: if isOwner(userId) || (isAuthenticated() && request.auth.uid == targetId);
        allow write: if isOwner(userId);
      }

      match /likes/{fromId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated() && request.auth.uid == fromId;
      }
    }

    // SAFETY REPORTS: Users can create, only Admins can view/manage.
    match /safety_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // VERIFICATION REQUESTS: Users can create, only Admins can view/manage.
    match /verification_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // SUBSCRIPTION PLANS: Public read, Admin-only write.
    match /plans/{planId} {
      allow read: if true; 
      allow create, update, delete: if isAuthenticated(); // Temporary rescue
    }

    // SUPPORT TICKETS: Users can see/create their own tickets, Admins see all.
    match /tickets/{ticketId} {
      allow read, update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated(); // Temporary rescue
    }

    // TRANSACTIONS: Users see their own history, Admins see all.
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.uid == request.auth.uid); 
      allow delete: if isAuthenticated(); // Temporary rescue
    }

    // MATCHES: Only participants can read/update matches.
    match /matches/{matchId} {
      allow read, update, delete: if isParticipant(resource.data) || isAuthenticated(); // Temporary rescue
      allow create: if isAuthenticated(); // Needed for initial match creation
      
      match /messages/{messageId} {
        // Use parent match data to verify participation
        allow read, delete: if isParticipant(get(/databases/$(database)/documents/matches/$(matchId)).data) || isAuthenticated(); // Temporary rescue
        allow create: if isParticipant(get(/databases/$(database)/documents/matches/$(matchId)).data);
        allow update: if isAuthenticated();
      }
    }

    // USERNAMES: Public read for checking availability, Admin write.
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // COUPONS: Public read (for validation), Admin-only write.
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated(); // Temporary rescue
    }

    // NOTIFICATIONS: Users see their own, Admins manage.
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAuthenticated(); // Temporary rescue
    }

    // ADS & ANALYTICS
    match /app_ads/{adId} {
      allow read: if true;
      allow update, delete: if isAuthenticated(); // Temporary rescue
      allow create: if isAuthenticated(); // Temporary rescue
    }
    
    match /ad_analytics/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated(); // Temporary rescue
    }

    // AD COMPANIES
    match /ad_companies/{companyId} {
      allow read, create, update, delete: if isAuthenticated(); // Temporary rescue
    }
  }
}
