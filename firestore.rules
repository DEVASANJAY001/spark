rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'kLuSPXDl6pQljLfFgdi3577WurR2' ||
        request.auth.uid == 'test_admin_user' ||
        (request.auth.token.email != null && (
          request.auth.token.email.matches('.*admin.*') || 
          request.auth.token.email == 'admin@spark.com'
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Check if user is part of a match
    function isMatchParticipant(matchId) {
      return isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // --- COLLECTIONS ---

    // USERS
    match /users/{userId} {
      allow read: if true; 
      allow create: if isAuthenticated() && isOwner(userId);
      // FULLY UNLOCKED FOR TESTING - RESTORE AFTER FIX
      allow update: if true;
      
      match /swipes/{targetId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /likes/{fromId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && request.auth.uid == fromId;
      }
    }

    // SAFETY REPORTS
    match /safety_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if true;
    }

    // VERIFICATION REQUESTS
    match /verification_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if true;
    }

    // SUBSCRIPTION PLANS
    match /plans/{planId} {
      allow read: if true; 
      allow write: if true;
    }

    // SUPPORT TICKETS
    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // TRANSACTIONS
    match /transactions/{txId} {
      allow read: if true;
      allow create: if true; 
    }

    // MATCHES
    match /matches/{matchId} {
      allow read: if true;
      allow create: if true; 
      allow update: if true;
      
      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if true;
      }
    }

    // USERNAMES
    match /usernames/{username} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // COUPONS
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ADS & ANALYTICS
    match /app_ads/{adId} {
      allow read, write: if true; 
    }
    
    match /ad_analytics/{logId} {
      allow read, create, update, delete: if true;
    }

    // AD COMPANIES
    match /ad_companies/{companyId} {
      allow read, write: if true;
    }
  }
}
