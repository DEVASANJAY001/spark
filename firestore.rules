rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is the owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper: Check if user is an Admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Allow read for Dashboard stats and User list
      allow read: if true; 
      // Allow creation for new signups
      allow create: if isAuthenticated() && isOwner(userId);
      // Allow update for Admin to ban users from Web or profile updates
      allow update: if true; 
      
      match /swipes/{targetId} {
        allow read, write: if true;
      }

      match /likes/{fromId} {
        allow read, write: if true;
      }
    }

    // --- SUBSCRIPTION PLANS ---
    match /plans/{planId} {
      allow read: if true; 
      allow write: if true; 
    }

    // --- SUPPORT TICKETS ---
    match /tickets/{ticketId} {
      allow read, write, update: if true;
    }

    // --- TRANSACTIONS ---
    match /transactions/{txId} {
      // Allow Dashboard to read all transactions for revenue calculation
      allow read, create: if true; 
    }

    // --- MATCHES & MESSAGES ---
    match /matches/{matchId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // --- USERNAMES ---
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if true;
    }

    // --- COUPONS ---
    match /coupons/{couponId} {
      allow read, write: if true;
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read, write: if true;
    }
  }
}
